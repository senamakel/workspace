#!/usr/bin/env bash
# build-agents — render shared agent definitions for Claude and Codex.
#
# Usage: build-agents [--check] [agent-name]
#
# Shared sources live in agents/<name>/{agent.json,instructions.md}.
# Generated outputs are written to claude/agents/<name>.md and
# codex/agents/<name>.toml. --check verifies outputs without changing them.
set -euo pipefail

fail() {
  printf '[FAIL] %s\n' "$*" >&2
}

require() {
  command -v "$1" >/dev/null 2>&1 \
    || { fail "missing required tool: $1"; exit 1; }
}

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
MODE="write"
FILTER=""

for arg in "$@"; do
  case "$arg" in
    --check) MODE="check" ;;
    -h|--help)
      sed -n '2,7p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    -*)
      fail "unknown argument: $arg"
      exit 1
      ;;
    *)
      [ -z "$FILTER" ] || { fail "only one agent name may be supplied"; exit 1; }
      FILTER="$arg"
      ;;
  esac
done

require jq
require rg

render_claude() {
  local metadata="$1" instructions="$2" output="$3"
  local name description tools model effort max_turns color
  name=$(jq -r '.name' "$metadata")
  description=$(jq -r '.description | @json' "$metadata")
  tools=$(jq -r '(.claude.tools // []) | join(", ")' "$metadata")
  model=$(jq -r '.claude.model' "$metadata")
  effort=$(jq -r '.claude.effort' "$metadata")
  max_turns=$(jq -r '.claude.maxTurns' "$metadata")
  color=$(jq -r '.claude.color' "$metadata")

  mkdir -p "$(dirname "$output")"
  {
    printf '%s\n' '---'
    printf '%s\n' '# Generated by bin/build-agents; edit agents/<name>/ instead.'
    printf 'name: %s\n' "$name"
    printf 'description: %s\n' "$description"
    [ -z "$tools" ] || printf 'tools: %s\n' "$tools"
    printf 'model: %s\n' "$model"
    printf 'effort: %s\n' "$effort"
    printf 'maxTurns: %s\n' "$max_turns"
    printf 'color: %s\n' "$color"
    printf '%s\n\n' '---'
    sed -n '1,$p' "$instructions"
  } >"$output"
}

render_codex() {
  local metadata="$1" instructions="$2" output="$3"
  local name description model effort
  name=$(jq -r '.name | @json' "$metadata")
  description=$(jq -r '.description | @json' "$metadata")
  model=$(jq -r '.codex.model | @json' "$metadata")
  effort=$(jq -r '.codex.modelReasoningEffort | @json' "$metadata")

  if rg -q '"""' "$instructions"; then
    fail "$instructions contains a TOML triple-quote delimiter"
    exit 1
  fi

  mkdir -p "$(dirname "$output")"
  {
    printf '%s\n' '# Generated by bin/build-agents; edit agents/<name>/ instead.'
    printf 'name = %s\n' "$name"
    printf 'description = %s\n' "$description"
    printf 'model = %s\n' "$model"
    printf 'model_reasoning_effort = %s\n' "$effort"
    printf '%s\n' 'developer_instructions = """'
    sed -n '1,$p' "$instructions"
    printf '%s\n' '"""'
  } >"$output"
}

validate_source() {
  local dir="$1"
  local metadata="$dir/agent.json" instructions="$dir/instructions.md"
  local name

  [ -f "$metadata" ] || { fail "missing $metadata"; exit 1; }
  [ -f "$instructions" ] || { fail "missing $instructions"; exit 1; }
  jq -e '
    ((.name | type) == "string" and (.name | test("^[a-z0-9]+(-[a-z0-9]+)*$"))) and
    ((.description | type) == "string" and (.description | length) > 0) and
    ((.claude.model | type) == "string" and (.claude.model | length) > 0) and
    ((.claude.effort | type) == "string" and (.claude.effort | length) > 0) and
    ((.claude.maxTurns | type) == "number" and .claude.maxTurns > 0) and
    ((.claude.color | type) == "string" and (.claude.color | length) > 0) and
    (.claude.tools == null or ((.claude.tools | type) == "array" and (.claude.tools | length) > 0)) and
    ((.codex.model | type) == "string" and (.codex.model | length) > 0) and
    ((.codex.modelReasoningEffort | type) == "string" and (.codex.modelReasoningEffort | length) > 0)
  ' "$metadata" >/dev/null || { fail "invalid agent metadata: $metadata"; exit 1; }

  name=$(jq -r '.name' "$metadata")
  [ "$name" = "$(basename "$dir")" ] \
    || { fail "agent name '$name' must match directory $(basename "$dir")"; exit 1; }
}

check_output() {
  local expected="$1" actual="$2"
  if [ ! -f "$actual" ]; then
    fail "missing generated output: $actual"
    return 1
  fi
  if ! cmp -s "$expected" "$actual"; then
    fail "stale generated output: $actual"
    return 1
  fi
}

SOURCE_DIRS=()
if [ -n "$FILTER" ]; then
  [ -d "$ROOT/agents/$FILTER" ] || { fail "unknown agent: $FILTER"; exit 1; }
  SOURCE_DIRS=("$ROOT/agents/$FILTER")
else
  while IFS= read -r dir; do
    SOURCE_DIRS+=("$dir")
  done < <(find "$ROOT/agents" -mindepth 1 -maxdepth 1 -type d | sort)
fi
[ "${#SOURCE_DIRS[@]}" -gt 0 ] || { fail "no shared agents found"; exit 1; }

CHECK_ROOT=""
if [ "$MODE" = "check" ]; then
  CHECK_ROOT=$(mktemp -d "${TMPDIR:-/tmp}/build-agents.XXXXXX")
  trap 'rm -rf "$CHECK_ROOT"' EXIT
fi

FAILED=0
for dir in "${SOURCE_DIRS[@]}"; do
  validate_source "$dir"
  name=$(basename "$dir")
  metadata="$dir/agent.json"
  instructions="$dir/instructions.md"

  if [ "$MODE" = "check" ]; then
    render_claude "$metadata" "$instructions" "$CHECK_ROOT/claude/$name.md"
    render_codex "$metadata" "$instructions" "$CHECK_ROOT/codex/$name.toml"
    check_output "$CHECK_ROOT/claude/$name.md" "$ROOT/claude/agents/$name.md" || FAILED=1
    check_output "$CHECK_ROOT/codex/$name.toml" "$ROOT/codex/agents/$name.toml" || FAILED=1
  else
    render_claude "$metadata" "$instructions" "$ROOT/claude/agents/$name.md"
    render_codex "$metadata" "$instructions" "$ROOT/codex/agents/$name.toml"
    printf '[BUILD] %s\n' "$name"
  fi
done

[ "$FAILED" -eq 0 ] || exit 1
[ "$MODE" = "write" ] || printf '[PASS] generated agents are current\n'
