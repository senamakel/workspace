#!/usr/bin/env bash
# workflow-update — sync a workflow superproject and bump its submodule pointers.
#
# Usage: workflow-update [--no-commit]
#
# Run from anywhere inside a workflow repo (a superproject with submodules).
# Steps:
#   1. Fetch the canonical remote (upstream preferred, else origin) and merge
#      its default branch into the current branch.
#   2. For each first-level submodule (no recursion): fetch its canonical
#      remote and check out the tip of its default branch.
#   3. Stage the moved submodule pointers and commit them
#      ("Update submodule pointers"). --no-commit stages only.
set -euo pipefail

if [ -t 1 ]; then
  _R=$'\033[0;31m' _G=$'\033[0;32m' _Y=$'\033[0;33m' _B=$'\033[1m' _0=$'\033[0m'
else
  _R="" _G="" _Y="" _B="" _0=""
fi
pass()  { printf '%s[PASS]%s %s\n' "$_G" "$_0" "$*"; }
fail()  { printf '%s[FAIL]%s %s\n' "$_R" "$_0" "$*" >&2; }
warn()  { printf '%s[WARN]%s %s\n' "$_Y" "$_0" "$*" >&2; }
info()  { printf '%s[INFO]%s %s\n' "$_B" "$_0" "$*"; }

COMMIT=1
case "${1:-}" in
  --no-commit) COMMIT=0 ;;
  -h|--help) sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
  '') ;;
  *) fail "unknown argument: $1"; exit 1 ;;
esac

# Canonical remote of a repo dir: upstream if present, else origin.
canonical_remote() {
  git -C "$1" remote get-url upstream >/dev/null 2>&1 && echo upstream || echo origin
}

# Default branch of a remote (falls back to main, then master).
default_branch() {
  local dir="$1" remote="$2" ref
  ref=$(git -C "$dir" symbolic-ref --quiet "refs/remotes/$remote/HEAD" 2>/dev/null) \
    && { echo "${ref##*/}"; return; }
  if git -C "$dir" show-ref --verify --quiet "refs/remotes/$remote/main"; then
    echo main
  else
    echo master
  fi
}

TOPLEVEL="$(git rev-parse --show-toplevel 2>/dev/null)" \
  || { fail "not inside a git repository"; exit 1; }
cd "$TOPLEVEL"
[ -f .gitmodules ] || { fail "no .gitmodules here — not a workflow superproject"; exit 1; }

# ── 1. Sync the superproject ───────────────────────────────────────
REMOTE=$(canonical_remote .)
git fetch "$REMOTE" --prune
BRANCH=$(default_branch . "$REMOTE")
info "superproject: merging $REMOTE/$BRANCH into $(git branch --show-current || echo 'detached HEAD')"
git merge --no-edit "refs/remotes/$REMOTE/$BRANCH"

# Make sure submodules exist and match the (possibly moved) recorded pointers
# before we bump them; one level only.
git submodule sync
git submodule update --init

# ── 2. Bump each first-level submodule to its remote default branch ─
CHANGED=0
while IFS= read -r SM_PATH; do
  [ -d "$SM_PATH/.git" ] || [ -f "$SM_PATH/.git" ] || { warn "skipping $SM_PATH (not initialized)"; continue; }
  SM_REMOTE=$(canonical_remote "$SM_PATH")
  git -C "$SM_PATH" fetch "$SM_REMOTE" --prune
  SM_BRANCH=$(default_branch "$SM_PATH" "$SM_REMOTE")
  OLD=$(git -C "$SM_PATH" rev-parse --short HEAD)
  git -C "$SM_PATH" checkout --quiet "refs/remotes/$SM_REMOTE/$SM_BRANCH"
  NEW=$(git -C "$SM_PATH" rev-parse --short HEAD)
  if [ "$OLD" = "$NEW" ]; then
    info "$SM_PATH: up to date at $NEW ($SM_REMOTE/$SM_BRANCH)"
  else
    pass "$SM_PATH: $OLD -> $NEW ($SM_REMOTE/$SM_BRANCH)"
    git add "$SM_PATH"
    CHANGED=1
  fi
done < <(git config -f .gitmodules --get-regexp '^submodule\..*\.path$' | awk '{print $2}')

# ── 3. Commit the moved pointers ───────────────────────────────────
if [ "$CHANGED" = "0" ]; then
  pass "all submodule pointers already up to date"
elif [ "$COMMIT" = "1" ]; then
  git commit -m "Update submodule pointers" -m "$(git diff --cached --submodule=short --stat)"
  pass "committed submodule pointer update"
else
  info "pointer changes staged; commit skipped (--no-commit)"
fi
