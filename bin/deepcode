#!/usr/bin/env bash
# deepcode — Claude Code, but driven by DeepSeek models via OpenRouter.
#
# Usage: deepcode [claude args...]
#
#   deepcode                        interactive session on DeepSeek V4
#   deepcode -p "explain this repo"  one-shot print mode
#   deepcode --yolo                 pass any flag straight through to claude
#
# This is a thin wrapper: it sets the Anthropic-compatible OpenRouter
# endpoint and DeepSeek model mappings in this process only, then exec's
# `claude`. Your normal `claude` (pointed at Anthropic) is untouched.
#
# Requires OPENROUTER_API_KEY in the environment (kept out of this repo;
# set it in your ~/.zshrc). Model IDs can be overridden:
#
#   DEEPCODE_MODEL           main/heavy model  (default: deepseek/deepseek-v4-pro)
#   DEEPCODE_FAST_MODEL      fast/background    (default: deepseek/deepseek-v4-flash)
#   DEEPCODE_CONTEXT_WINDOW  auto-compact threshold in tokens (default: 300000).
#                            DeepSeek V4 advertises 1M but loses accuracy well
#                            before it, so we compact by ~300k. Set to a bigger
#                            number (or empty) to use the model's full window.
set -euo pipefail

if [ -z "${OPENROUTER_API_KEY:-}" ]; then
  echo "deepcode: OPENROUTER_API_KEY is not set." >&2
  echo "  Add it to your ~/.zshrc: export OPENROUTER_API_KEY=sk-or-..." >&2
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "deepcode: 'claude' CLI not found on PATH." >&2
  exit 1
fi

pro="${DEEPCODE_MODEL:-deepseek/deepseek-v4-pro}"
flash="${DEEPCODE_FAST_MODEL:-deepseek/deepseek-v4-flash}"

# Route through OpenRouter's Anthropic-compatible endpoint.
export ANTHROPIC_BASE_URL="https://openrouter.ai/api"
export ANTHROPIC_AUTH_TOKEN="$OPENROUTER_API_KEY"
export ANTHROPIC_API_KEY=""   # blank so the SDK uses the auth token above

# Map Claude tiers onto DeepSeek: Opus -> pro (heavy, for coding/deep review);
# Sonnet + Haiku -> flash (the token-saving tiers). This matches the agent model
# tiering, so a Sonnet-tier agent is cheap under deepcode as well as Anthropic.
export ANTHROPIC_DEFAULT_OPUS_MODEL="$pro"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$flash"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$flash"
export ANTHROPIC_SMALL_FAST_MODEL="$flash"   # legacy name, still honored
# No CLAUDE_CODE_SUBAGENT_MODEL override: subagents follow their own model tier,
# so Opus-tier coding/review agents stay on pro while Sonnet/Haiku land on flash.

# Cap the effective context: DeepSeek V4's 1M window loses accuracy past ~300k,
# so auto-compact at 300k (session-global — applies to whichever tier is active)
# instead of the ~967k default. Blank DEEPCODE_CONTEXT_WINDOW to keep the default.
context="${DEEPCODE_CONTEXT_WINDOW-300000}"
[ -z "$context" ] || export CLAUDE_CODE_AUTO_COMPACT_WINDOW="$context"

exec claude "$@"
