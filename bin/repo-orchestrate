#!/usr/bin/env bash
# repo-orchestrate — spin up the repo-orchestrator loop in a chosen harness.
#
# Usage: repo-orchestrate [claude|codex|opencode|deepcode|deepcode-flash] [options] [extra prompt...]
#
#   repo-orchestrate                   review + merge/work/close/fix all open issues + PRs (claude)
#   repo-orchestrate codex             same, with codex
#   repo-orchestrate --triage-only     only triage/prepare/surface; take no irreversible action
#   repo-orchestrate --no-merge        do everything except merge PRs
#   repo-orchestrate -R owner/name     orchestrate another repo
#   repo-orchestrate codex --no-take-up "focus on the release milestone"
#
# Launches the chosen harness from the repo root, seeded with a prompt that makes
# it act as the repo-orchestrator agent: enumerate every open issue and pull
# request, classify each, and route them to the pr-*/gh commands and subagents —
# reviewing everything, then merging, working, closing, and fixing as much as it
# can, using subagents and background jobs, and looping until the board is in a
# known state. Prefers the `upstream` remote (the canonical repo) over `origin`.
#
# The harness is launched WITHOUT permission-bypass flags: the orchestrator acts
# strictly within the permission system and never bypasses a prompt, sandbox, or
# approval. Anything it lacks permission for is surfaced, not forced.
#
# Options:
#   --triage-only      triage, prepare, and surface only — no merges, no new work
#   --no-merge         do everything except merge PRs
#   --no-take-up       do everything except start net-new work on issues
#   --sentry           also run Sentry triage (dispatch sentry-triager for the
#                      repo's bound Sentry project; needs `sentry-repo` bound)
#   -R, --repo O/N     override repo resolution (else REPO_ORCH_REPO, else remote)
#   --limit N          hint the PR census to the N most recent open PRs
#
# Env: REPO_ORCH_REPO=owner/name overrides repo resolution.
#      REPO_ORCH_YOLO=1 launches with permission-bypass flags (NOT recommended;
#      the orchestrator is designed to run within the permission system).
set -euo pipefail

# ── Coloured output (disabled when stdout is not a terminal) ───────
if [ -t 1 ]; then
  _R=$'\033[0;31m' _G=$'\033[0;32m' _Y=$'\033[0;33m' _B=$'\033[1m' _0=$'\033[0m'
else
  _R="" _G="" _Y="" _B="" _0=""
fi
pass()  { printf '%s[PASS]%s %s\n' "$_G" "$_0" "$*"; }
fail()  { printf '%s[FAIL]%s %s\n' "$_R" "$_0" "$*" >&2; }
warn()  { printf '%s[WARN]%s %s\n' "$_Y" "$_0" "$*" >&2; }
info()  { printf '%s[INFO]%s %s\n' "$_B" "$_0" "$*"; }

usage() {
  sed -n '2,35p' "$0" | sed 's/^# \{0,1\}//'
  exit 1
}

require() {
  local bin
  for bin in "$@"; do
    command -v "$bin" >/dev/null 2>&1 || { fail "missing required tool: $bin"; exit 1; }
  done
}

resolve_repo() {
  if [ -n "${REPO_ORCH_REPO:-}" ]; then
    echo "$REPO_ORCH_REPO"
    return
  fi
  local url
  url=$(git remote get-url upstream 2>/dev/null || git remote get-url origin)
  echo "$url" \
    | sed -E 's#^git@github\.com:##; s#^https?://github\.com/##; s#\.git$##'
}

# ── Harness registry (kept in sync with bin/pr-fix) ────────────────
HARNESSES="claude codex opencode deepcode deepcode-flash"

is_harness() {
  case " $HARNESSES " in *" $1 "*) return 0 ;; *) return 1 ;; esac
}

# harness_launch <name> <prompt> <mode>
harness_launch() {
  local name="$1" prompt="$2" mode="$3"
  case "$name" in
    claude)
      if [ "$mode" = safe ]; then claude "$prompt"
      else claude --dangerously-skip-permissions "$prompt"; fi ;;
    deepcode)
      if [ "$mode" = safe ]; then deepcode "$prompt"
      else deepcode --dangerously-skip-permissions "$prompt"; fi ;;
    deepcode-flash)
      if [ "$mode" = safe ]; then deepcode-flash "$prompt"
      else deepcode-flash --dangerously-skip-permissions "$prompt"; fi ;;
    codex)
      if [ "$mode" = safe ]; then codex "$prompt"
      else codex --dangerously-bypass-approvals-and-sandbox "$prompt"; fi ;;
    opencode)
      if [ "$mode" = safe ]; then opencode --prompt "$prompt"
      else opencode --prompt "$prompt" --auto; fi ;;
    *)
      fail "unknown harness: $name"; exit 1 ;;
  esac
}

# ── Parse args ─────────────────────────────────────────────────────
AGENT="claude"
REPO_OVERRIDE=""
DO_MERGE=1
DO_TAKEUP=1
DO_SENTRY=0
LIMIT=""
EXTRA_PARTS=()

while [ $# -gt 0 ]; do
  case "$1" in
    --triage-only)    DO_MERGE=0; DO_TAKEUP=0; shift ;;
    --no-merge)       DO_MERGE=0; shift ;;
    --no-take-up)     DO_TAKEUP=0; shift ;;
    --sentry)         DO_SENTRY=1; shift ;;
    -R|--repo)        [ $# -ge 2 ] || { fail "$1 requires owner/name"; usage; }
                      REPO_OVERRIDE="$2"; shift 2 ;;
    --limit)          [ $# -ge 2 ] || { fail "--limit requires a number"; usage; }
                      LIMIT="$2"; shift 2 ;;
    -h|--help)        usage ;;
    -*)               fail "unknown option: $1"; usage ;;
    *)
      if is_harness "$1"; then AGENT="$1"
      else EXTRA_PARTS+=("$1"); fi
      shift ;;
  esac
done
[ -z "$LIMIT" ] || case "$LIMIT" in *[!0-9]*) fail "--limit must be numeric: $LIMIT"; usage;; esac
[ -z "$REPO_OVERRIDE" ] || REPO_ORCH_REPO="$REPO_OVERRIDE"
EXTRA="${EXTRA_PARTS[*]:-}"

require git gh jq pr-list "$AGENT"

TOPLEVEL="$(git rev-parse --show-toplevel 2>/dev/null)" \
  || { fail "not inside a git repository"; exit 1; }
cd "$TOPLEVEL"

REPO="$(resolve_repo)"
REMOTE="upstream"
git remote get-url upstream >/dev/null 2>&1 || REMOTE="origin"
info "repo: $REPO (canonical remote: $REMOTE)"

if [ "$DO_MERGE" = "1" ]; then
  MERGE_LINE="AUTHORIZED — merge any PR that passes \`pr-merge <n> --dry-run\` with zero blockers (via the permission system; never bypass a prompt). Never merge a PR that fails any gate, is a draft, or is unreviewed."
  info "merge: AUTHORIZED (gate-passing PRs, within permissions)"
else
  MERGE_LINE="WITHHELD (--no-merge) — do NOT merge. Prepare PRs to merge-ready and LIST them for the human."
  info "merge: WITHHELD (--no-merge)"
fi

if [ "$DO_TAKEUP" = "1" ]; then
  TAKEUP_LINE="AUTHORIZED — start net-new work on CAN-BE-TAKEN-UP / READY issues: create a worktree with \`worktree <slug>\`, drive it through the workflow skills (brainstorming if needed -> plan-writer -> subagent-driven-development -> finishing-a-development-branch) as background jobs, and open a PR. Never take up an item that already has an active PR."
  info "take-up: AUTHORIZED (start ready work, within permissions)"
else
  TAKEUP_LINE="WITHHELD (--no-take-up) — do NOT start implementation. SURFACE take-up candidates with your recommendation (owner, effort, ROI)."
  info "take-up: WITHHELD (--no-take-up)"
fi

if [ "$DO_SENTRY" = "1" ]; then
  SENTRY_LINE="ENABLED — also run the Sentry intake (Intake C): dispatch the sentry-triager subagent (or run \`sentry-triage\`) for this repo's bound Sentry project. Check \`sentry-repo\` first; if UNRESOLVED, skip it and note it needs binding."
  info "sentry: ENABLED (dispatch sentry-triager)"
else
  SENTRY_LINE="DISABLED — do not run the Sentry intake."
fi

LIMIT_LINE=""
[ -z "$LIMIT" ] || LIMIT_LINE="PR census hint: start with \`pr-list --json --limit $LIMIT\`."

# ── Build the orchestration prompt ─────────────────────────────────
# Single source of truth: embed the canonical playbook (the same file
# build-agents renders into the installed agent) instead of duplicating it here,
# so the two never drift. Fall back to a reference if the source isn't found.
PLAYBOOK_FILE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)/agents/repo-orchestrator/instructions.md"
if [ -f "$PLAYBOOK_FILE" ]; then
  PLAYBOOK="$(cat "$PLAYBOOK_FILE")"
else
  warn "playbook source not found at $PLAYBOOK_FILE; referencing the installed agent"
  PLAYBOOK="Act as the repo-orchestrator agent — read ~/.claude/agents/repo-orchestrator.md (Claude) or ~/.codex/agents/repo-orchestrator.toml (Codex) and follow it exactly."
fi

PROMPT="$PLAYBOOK

--- LAUNCH CONFIGURATION (this run) ---
You are the Repo Orchestrator for the repository ${REPO} (canonical remote: ${REMOTE}).
Merge authority: ${MERGE_LINE}
Take-up authority: ${TAKEUP_LINE}
Sentry intake: ${SENTRY_LINE}
${LIMIT_LINE}"

[ -z "$EXTRA" ] || PROMPT="$PROMPT

Additional instructions: $EXTRA"

# Default to SAFE: the orchestrator runs within the permission system and never
# bypasses prompts. REPO_ORCH_YOLO=1 opts into permission-bypass flags (not
# recommended — it defeats the point of an in-permissions orchestrator).
if [ "${REPO_ORCH_YOLO:-0}" = "1" ]; then
  warn "permission mode: BYPASS (REPO_ORCH_YOLO=1) — permission prompts are skipped"
  LAUNCH_MODE="yolo"
else
  info "permission mode: SAFE (no bypass — sensitive actions will prompt for permission)"
  LAUNCH_MODE="safe"
fi

info "launching $AGENT as repo orchestrator in $TOPLEVEL"
set +e
harness_launch "$AGENT" "$PROMPT" "$LAUNCH_MODE"
AGENT_STATUS=$?
set -e
[ "$AGENT_STATUS" -eq 0 ] || warn "$AGENT exited with status $AGENT_STATUS"
pass "orchestration session ended"
