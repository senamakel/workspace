#!/usr/bin/env bash
# worktree — create an agent-ready Git worktree and initialize submodules.
#
# Usage: worktree <slug> [--json]
#
# Creates or reuses branch <slug> at <repo>/worktree/<slug>. New branches start
# at the current HEAD. Submodules are initialized recursively in the resulting
# worktree. The final report is stable and suitable for agent orchestration.
set -euo pipefail

fail() {
  printf '[FAIL] %s\n' "$*" >&2
}

usage() {
  sed -n '2,8p' "$0" | sed 's/^# \{0,1\}//'
}

require() {
  local bin
  for bin in "$@"; do
    command -v "$bin" >/dev/null 2>&1 \
      || { fail "missing required tool: $bin"; exit 1; }
  done
}

SLUG=""
FORMAT="text"

while [ $# -gt 0 ]; do
  case "$1" in
    --json)
      FORMAT="json"
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      fail "unknown argument: $1"
      usage
      exit 1
      ;;
    *)
      [ -z "$SLUG" ] || { fail "only one slug may be supplied"; usage; exit 1; }
      SLUG="$1"
      shift
      ;;
  esac
done

case "$SLUG" in
  ''|*[!A-Za-z0-9._-]*|.*|*..*|*.lock)
    fail "slug must be one path segment using letters, numbers, dots, underscores, or hyphens"
    exit 1
    ;;
esac

require git jq
git check-ref-format --branch "$SLUG" >/dev/null 2>&1 \
  || { fail "slug is not a valid Git branch name: $SLUG"; exit 1; }

TOPLEVEL=$(git rev-parse --show-toplevel 2>/dev/null) \
  || { fail "not inside a Git repository"; exit 1; }
WT_PARENT="$TOPLEVEL/worktree"
WT_DIR="$WT_PARENT/$SLUG"
CREATED=true

if [ -e "$WT_DIR/.git" ]; then
  ACTUAL_ROOT=$(git -C "$WT_DIR" rev-parse --show-toplevel 2>/dev/null) \
    || { fail "target has .git metadata but is not a usable worktree: $WT_DIR"; exit 1; }
  ACTUAL_BRANCH=$(git -C "$WT_DIR" branch --show-current)
  [ "$ACTUAL_ROOT" = "$WT_DIR" ] \
    || { fail "registered worktree root does not match target: $ACTUAL_ROOT"; exit 1; }
  [ "$ACTUAL_BRANCH" = "$SLUG" ] \
    || { fail "target already contains branch '$ACTUAL_BRANCH', expected '$SLUG'"; exit 1; }
  CREATED=false
elif [ -e "$WT_DIR" ]; then
  fail "target exists but is not a registered Git worktree: $WT_DIR"
  exit 1
else
  mkdir -p "$WT_PARENT"
  if git show-ref --verify --quiet "refs/heads/$SLUG"; then
    if ! WORKTREE_OUTPUT=$(git worktree add "$WT_DIR" "$SLUG" 2>&1); then
      fail "could not attach existing branch '$SLUG'"
      printf '%s\n' "$WORKTREE_OUTPUT" >&2
      exit 1
    fi
  else
    if ! WORKTREE_OUTPUT=$(git worktree add -b "$SLUG" "$WT_DIR" HEAD 2>&1); then
      fail "could not create branch and worktree '$SLUG'"
      printf '%s\n' "$WORKTREE_OUTPUT" >&2
      exit 1
    fi
  fi
fi

if ! SUBMODULE_OUTPUT=$(git -C "$WT_DIR" submodule update --init --recursive 2>&1); then
  fail "worktree exists, but recursive submodule initialization failed: $WT_DIR"
  printf '%s\n' "$SUBMODULE_OUTPUT" >&2
  exit 1
fi

SUBMODULE_COUNT=0
if [ -f "$WT_DIR/.gitmodules" ]; then
  SUBMODULE_COUNT=$(git -C "$WT_DIR" config -f .gitmodules --get-regexp 'submodule\..*\.path' 2>/dev/null \
    | wc -l | tr -d ' ')
fi

BRANCH=$(git -C "$WT_DIR" branch --show-current)
HEAD_SHA=$(git -C "$WT_DIR" rev-parse HEAD)
HEAD_SHORT=$(git -C "$WT_DIR" rev-parse --short HEAD)
NEXT_COMMAND=$(printf 'cd %q' "$WT_DIR")

REPORT=$(jq -n \
  --arg repository "$TOPLEVEL" \
  --arg path "$WT_DIR" \
  --arg branch "$BRANCH" \
  --arg head "$HEAD_SHA" \
  --arg headShort "$HEAD_SHORT" \
  --arg nextCommand "$NEXT_COMMAND" \
  --argjson created "$CREATED" \
  --argjson submoduleCount "$SUBMODULE_COUNT" '
  {
    status: "ready",
    repository: $repository,
    path: $path,
    branch: $branch,
    head: $head,
    headShort: $headShort,
    created: $created,
    submodules: {
      state: "initialized_recursive",
      count: $submoduleCount
    },
    nextCommand: $nextCommand
  }
')

if [ "$FORMAT" = "json" ]; then
  jq . <<<"$REPORT"
else
  jq -r '
    "[PASS] WORKTREE_READY",
    "  repository: \(.repository)",
    "  path: \(.path)",
    "  branch: \(.branch)",
    "  head: \(.headShort)",
    "  created: \(.created)",
    "  submodules: \(.submodules.state) (\(.submodules.count))",
    "  next: \(.nextCommand)"
  ' <<<"$REPORT"
fi
